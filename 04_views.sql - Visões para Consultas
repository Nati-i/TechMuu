-- =============================================
-- VIEWS (VISÕES)
-- =============================================
-- Descrição: Consultas reutilizáveis para o frontend

-- VIEW 1: Detalhes de cada vaca com informações do produtor E coleira
CREATE OR REPLACE VIEW vw_vaca_detalhes AS 
SELECT
    v.id_vaca,
    v.identificador,
    v.raca,
    v.estado_reprodutivo,
    p.nome AS produtor,
    c.serial AS coleira,
    c.id_coleira,
    c.status AS status_coleira,
    c.bateria_percent,
    c.ultimo_sync,
    v.data_nascimento,
    v.observacoes
FROM vaca v 
JOIN produtor p ON v.id_produtor = p.id_produtor
LEFT JOIN coleira c ON v.id_coleira = c.id_coleira;

-- VIEW 2: Alertas recentes (últimos 7 dias) com info da vaca E coleira
CREATE OR REPLACE VIEW vw_alertas_recentes AS 
SELECT
    a.id_alerta,
    v.id_vaca,
    v.identificador AS vaca_identificador,
    c.id_coleira,
    c.serial AS coleira_serial,
    a.tipo_alerta,
    a.descricao,
    a.nivel,
    a.gerado_em,
    a.resolvido
FROM alerta a 
JOIN vaca v ON a.id_vaca = v.id_vaca
LEFT JOIN coleira c ON a.id_coleira = c.id_coleira
WHERE a.gerado_em > (now() - INTERVAL '7 days')
ORDER BY a.gerado_em DESC;

-- VIEW 3: Status das coleiras ativas com última leitura
CREATE OR REPLACE VIEW vw_coleiras_status AS
SELECT
    c.id_coleira,
    c.serial,
    c.modelo,
    c.status,
    c.bateria_percent,
    c.ultimo_sync,
    COUNT(v.id_vaca) AS vacas_associadas,
    (SELECT temperatura FROM leitura_sensor WHERE id_coleira = c.id_coleira ORDER BY data_hora DESC LIMIT 1) AS ultima_temperatura,
    (SELECT data_hora FROM leitura_sensor WHERE id_coleira = c.id_coleira ORDER BY data_hora DESC LIMIT 1) AS data_ultima_leitura
FROM coleira c
LEFT JOIN vaca v ON c.id_coleira = v.id_coleira
GROUP BY c.id_coleira, c.serial, c.modelo, c.status, c.bateria_percent, c.ultimo_sync;

-- VIEW 4: Leituras recentes com info completa (vaca + coleira)
CREATE OR REPLACE VIEW vw_leituras_recentes AS
SELECT
    ls.id_leitura,
    v.id_vaca,
    v.identificador AS vaca_id,
    c.id_coleira,
    c.serial AS coleira_serial,
    ls.data_hora,
    ls.temperatura,
    ls.atividade,
    ls.tempo_ruminacao_min,
    ls.bateria_percent,
    ls.origem
FROM leitura_sensor ls
JOIN vaca v ON ls.id_vaca = v.id_vaca
JOIN coleira c ON ls.id_coleira = c.id_coleira
ORDER BY ls.data_hora DESC;
